# Environment variables - DO NOT COMMIT TO GIT!
# Copy this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI provider configuration
# Supported providers: gemini, deepseek
AI_PROVIDER=gemini
AI_MODEL=gemini-3-flash-preview

# Gemini API Key (get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API Key (optional fallback; get from platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your_project_id_here
# Optional explicit Firestore project override
FIRESTORE_PROJECT_ID=your_project_id_here

# Optional: comma-separated Telegram user IDs that can use /admin_status
ADMIN_TELEGRAM_IDS=123456789,987654321

# Optional: Path to service account key for local development
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
